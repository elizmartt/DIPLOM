{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "DiagnosisOrchestrator": "Debug"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "TimescaleDB": "Host=localhost;Port=5432;Database=medical_diagnosis;Username=postgres;Password=your_password;Pooling=true;Maximum Pool Size=20;"
  },
  
  "OrchestratorOptions": {
    "ModuleWeights": {
      "Imaging": 0.40,
      "Clinical": 0.30,
      "Laboratory": 0.30
    },
    "ConfidenceThreshold": 0.70,
    "MinModulesRequired": 2,
    "TimeoutSeconds": 30,
    "EnableParallelProcessing": true,
    "EnsembleStrategy": "WeightedVoting"
  },
  
  "ModuleEndpoints": {
    "ImagingServiceUrl": "http://localhost:5001/api/imaging",
    "ClinicalServiceUrl": "http://localhost:5002/api/clinical",
    "LaboratoryServiceUrl": "http://localhost:5003/api/laboratory"
  },

  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ImagingRequestTopic": "imaging-requests",
    "ClinicalRequestTopic": "clinical-requests",
    "LabRequestTopic": "lab-requests",
    "ImagingResultTopic": "imaging-results",
    "ClinicalResultTopic": "clinical-results",
    "LabResultTopic": "lab-results",
    "DiagnosisRequestTopic": "diagnosis-requests",
    "DiagnosisResultTopic": "diagnosis-results",
    "ClientId": "diagnosis-orchestrator",
    "MessageTimeoutMs": 10000
  }
}
